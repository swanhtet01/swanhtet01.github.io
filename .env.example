# SuperMega Mark 1 environment variables
# Copy this file to .env and fill in your values.

# Core models
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Pilot source configuration
YANGON_TYRE_LOCAL_ROOT=C:/Users/swann/OneDrive - BDA/Yangon Tyre
YANGON_TYRE_DRIVE_FOLDER_ID=1lvNk73XNxIdPIagwal7YKEzlCtAkk-yv
GOOGLE_CLOUD_PROJECT=supermega-468612
VERTEX_AI_LOCATION=asia-southeast1

# Secrets are file paths, not raw JSON pasted into .env
GOOGLE_SERVICE_ACCOUNT_JSON=./.secrets/yangon-tyre.service-account.json
GMAIL_OAUTH_CLIENT_JSON=./.secrets/gmail-oauth-client.json
GMAIL_OAUTH_TOKEN_JSON=./.secrets/gmail-oauth-token.json

# Optional automation and repo access
GITHUB_TOKEN=
FLOWISE_PASSWORD=mark1admin

# Google sign-in for the live app. Prefer the web client JSON path.
SUPERMEGA_GOOGLE_AUTH_ENABLED=0
SUPERMEGA_GOOGLE_AUTH_ALLOW_AUTO_PROVISION=1
GOOGLE_OAUTH_CLIENT_JSON=./.secrets/google-oauth-client.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_ALLOWED_DOMAINS=

# Optional pilot paths
PILOT_CONFIG_PATH=./config.example.json
PILOT_OUTPUT_DIR=./pilot-data

# App runtime
SUPERMEGA_SITE_ROOT=./showroom/dist
SUPERMEGA_PILOT_DATA=./pilot-data
SUPERMEGA_CORS_ORIGINS=http://localhost:8787

# Optional showroom lead API endpoint (used by showroom/contact form)
VITE_LEAD_ENDPOINT=
