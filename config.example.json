      "**/*claim*",
      "**/*shipment*",
      "**/*quality*"
    ],
    "focus_file": "erp_focus_terms.txt",
    "focus_report_file": "erp_focus_report.json",
    "focus_markdown_file": "erp_focus_report.md"
  },
  "output": {
